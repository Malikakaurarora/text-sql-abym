# Copy this file to .env and fill in your values.
# Never commit .env to git.

# OpenRouter free API key — get one at openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# PostgreSQL connection string (used by server.py and migrate_postgres.py).
# When running with Docker Compose this is already set in docker-compose.yml.
# For local SQLite dev, leave this blank — server.py falls back to library2.db.
DATABASE_URL=postgresql://postgres:password@localhost:5432/library

# --- Optional: other versions ---
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# FastAPI server URL (used by Streamlit client)
SERVER_URL=http://localhost:8000
